# Copy to `.env.local` (gitignored) and fill in. Never commit real secrets.

# --- Required now ---

# Anthropic Claude API key. Powers the AI orchestration layer (src/lib/ai)
# and the `pnpm smoke:claude` connectivity test.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Direct Postgres connection string for server-side queries and Drizzle
# migrations (Dashboard > Project Settings > Database > Connection string).
# The ONLY database credential the app reads — it talks to Postgres via
# postgres.js, never the Supabase JS client.
DATABASE_URL=

# --- Public-endpoint cost protection (ADR-0007); optional, sane defaults ---

# Max chat requests per IP per window (fixed window in Postgres).
CHAT_RATE_LIMIT_MAX=8
CHAT_RATE_LIMIT_WINDOW_MINUTES=10

# Daily spend ceiling for the public chat, in integer microdollars
# (1,000,000 = $1). Sensor is the spans table (mlip.chat_turn cost);
# the Anthropic Console spend cap remains the hard backstop.
CHAT_DAILY_BUDGET_MICROUSD=2000000
